# Last.FM (https://www.last.fm/api/account/create)
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_USERNAME=your_lastfm_username_here

# Fanart.tv (https://fanart.tv/get-an-api-key)
FANART_TV_API_KEY=your_fanart_tv_api_key_here

# Database (overridden by docker-compose.prod.yml when running in Docker)
DATABASE_URL=postgresql://encore:changeme@localhost:5432/encore
POSTGRES_DB=encore
POSTGRES_USER=encore
POSTGRES_PASSWORD=changeme

# Redis (overridden by docker-compose.prod.yml when running in Docker)
REDIS_URL=redis://localhost:6379

# Eversolo streamer local IP (optional — enables now-playing integration)
EVERSOLO_HOST=

# New releases window in days (default: 90)
NEW_RELEASES_DAYS_WINDOW=90

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here
